ovesá sú ohybné slová","číslovky vyjadrujú počet","modálne slovesá patria medzi neplnovýznamové","jeho, jej, ich sú nesklonné zámená"]},{"id":2927,"type":"matching","question":"Priraď slovný druh k príkladu.","pairs":[{"term":"zámeno","match":"oni"},{"term":"číslovka","match":"päť"},{"term":"sloveso","match":"kreslí"}],"correctAnswer":{"zámeno":"oni","číslovka":"päť","sloveso":"kreslí"}},{"id":2928,"type":"matching","question":"Priraď slovesnú kategóriu k príkladu.","pairs":[{"term":"čas","match":"prítomný"},{"term":"spôsob","match":"oznamovací"},{"term":"vid","match":"dokonavý"},{"term":"rod","match":"trpný"}],"correctAnswer":{"čas":"prítomný","spôsob":"oznamovací","vid":"dokonavý","rod":"trpný"}},{"id":2929,"type":"ordering","question":"Usporiadaj neurčité slovesné tvary podľa zoznamu v učive.","options":["prechodník","trpné príčastie","slovesné podstatné meno","neurčitok"],"correctAnswer":["prechodník","trpné príčastie","slovesné podstatné meno","neurčitok"]},{"id":2930,"type":"single","question":"Vo vete „Jej vlasy boli krásne.“ je slovo „jej“:","options":["osobné privlastňovacie zámeno","ukazovacie zámeno","zvratné zámeno","neurčitá číslovka"],"correctAnswer":"osobné privlastňovacie zámeno"},{"id":2931,"type":"single","question":"Čo je staroveká literatúra?","options":["Literatúra od približne 3500 pred n. l. do 5. storočia n. l.","Literatúra stredoveku a renesancie","Iba antická grécka literatúra","Len orientálna náboženská literatúra"],"correctAnswer":"Literatúra od približne 3500 pred n. l. do 5. storočia n. l."},{"id":2932,"type":"multiple","question":"Ktoré literatúry patria do starovekej orientálnej literatúry?","options":["sumerská","akkadská","staroegyptská","indická","hebrejská","francúzska"],"correctAnswer":["sumerská","akkadská","staroegyptská","indická","hebrejská"]},{"id":2933,"type":"single","question":"Kde vznikla sumerská literatúra?","options":["V Mezopotámii","V Egypte","V Palestíne","V Grécku"],"correctAnswer":"V Mezopotámii"},{"id":2934,"typ